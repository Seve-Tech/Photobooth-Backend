# Copy this file to .env and fill in the values
# cp .env.example .env

# ── App ──────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Security ─────────────────────────────────────
# API_KEY: The shared secret that all REST callers and WebSocket clients must provide.
#   REST clients  → send it as a header:      X-API-Key: <value>
#   WS clients    → send it as a query param: ws://host/ws?api_key=<value>
# Change this to a long random string (e.g. generate with: openssl rand -hex 32)
API_KEY=change-me-to-a-long-random-string

# FRONTEND_ORIGIN — the exact origin of your front-end app (used for CORS).
#           Only requests from this origin will be accepted by the browser.
#           Examples:
#             Local dev:   http://localhost:3000
#             Production:  https://photobooth.yourdomain.com
FRONTEND_ORIGIN=http://localhost:3000

# WS_RATE_LIMIT — max WebSocket messages a single client can send per minute.
#           Default (30) allows ~6 bills/min. Raise if you expect faster usage.
WS_RATE_LIMIT=30

# ── Database ─────────────────────────────────────
# asyncpg DSN — no driver prefix needed, just:
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/photobooth_db

# Machine identity — set these once per physical photobooth deployment.
# BRANCH_ID: the ID of the branch this machine belongs to (from the branches table).
# UNIT_ID:   the ID of this specific photobooth unit (from the photobooth_units table).
BRANCH_ID=1
UNIT_ID=1

# ── DSLRBooth Integration ─────────────────────────
# Set DSLRBOOTH_MOCK=true during local development (no DSLRBooth installed)
# Set DSLRBOOTH_MOCK=false on the client's Mini PC for production
DSLRBOOTH_MOCK=true
DSLRBOOTH_HOST=http://localhost:1500
DSLRBOOTH_PASSWORD=                    # Get this from DSLRBooth Settings → General → API tab
DSLRBOOTH_BOOTH_MODE=print             # Options: print, gif, boomerang, video
DSLRBOOTH_SESSION_TIMEOUT_S=300        # Max seconds to wait before timing out
DSLRBOOTH_MOCK_SESSION_DURATION_S=10   # Mock session duration in seconds
