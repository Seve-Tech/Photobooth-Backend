# Copy this file to .env and fill in the values
# cp .env.example .env

# ── App ──────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────
# Set this once the DB person is ready.
# Examples:
#   PostgreSQL:  postgresql+asyncpg://user:password@localhost:5432/photobooth
#   MySQL:       mysql+aiomysql://user:password@localhost:3306/photobooth
#   SQLite:      sqlite:///./photobooth.db   (default, for local dev)
DATABASE_URL=sqlite:///./photobooth_dev.db
